# Configuração de Ambiente do Sistema DeepFake Detection
# Copie este arquivo para .env e ajuste os valores conforme necessário

# === CONFIGURAÇÕES GERAIS ===
DEEPFAKE_ENV=development
DEEPFAKE_DEBUG=true
DEEPFAKE_VERSION=1.0.0

# === CAMINHOS ===
DEEPFAKE_BASE_DIR=./deepfake_system
DEEPFAKE_DATA_DIR=./app/datasets
DEEPFAKE_LOGS_DIR=./logs
DEEPFAKE_TEMP_DIR=./data/temp
DEEPFAKE_MODELS_DIR=./app/models
DEEPFAKE_UPLOADS_DIR=./data/uploads
XFAKE_STORAGE_DIR=./data

# === CONFIGURAÇÕES DE ÁUDIO ===
DEEPFAKE_SAMPLE_RATE=22050
DEEPFAKE_N_FFT=2048
DEEPFAKE_HOP_LENGTH=512
DEEPFAKE_N_MELS=128
DEEPFAKE_MAX_DURATION=30.0
DEEPFAKE_MIN_DURATION=1.0
DEEPFAKE_NORMALIZE=true
DEEPFAKE_REMOVE_SILENCE=true

# === CONFIGURAÇÕES DE FEATURES ===
DEEPFAKE_MFCC_COEFFS=13
DEEPFAKE_DELTA_FEATURES=true
DEEPFAKE_NORMALIZE_FEATURES=true
DEEPFAKE_CACHE_FEATURES=true
DEEPFAKE_PARALLEL_EXTRACTION=true
DEEPFAKE_MAX_WORKERS=4

# === CONFIGURAÇÕES DE TREINAMENTO ===
DEEPFAKE_BATCH_SIZE=32
DEEPFAKE_EPOCHS=100
DEEPFAKE_LEARNING_RATE=0.001
DEEPFAKE_VALIDATION_SPLIT=0.2
DEEPFAKE_OPTIMIZER=adam
DEEPFAKE_LOSS_FUNCTION=binary_crossentropy
DEEPFAKE_USE_AUGMENTATION=true
DEEPFAKE_EARLY_STOPPING_PATIENCE=10

# === CONFIGURAÇÕES DA API ===
DEEPFAKE_API_HOST=localhost
DEEPFAKE_API_PORT=8000
DEEPFAKE_API_DEBUG=true
DEEPFAKE_API_WORKERS=1
DEEPFAKE_MAX_REQUEST_SIZE=104857600
DEEPFAKE_API_TIMEOUT=300
DEEPFAKE_CORS_ENABLED=true

# === CONFIGURAÇÕES DO BANCO DE DADOS ===
DEEPFAKE_DB_TYPE=sqlite
DEEPFAKE_DB_HOST=localhost
DEEPFAKE_DB_PORT=5432
DEEPFAKE_DB_NAME=deepfake_detection
DEEPFAKE_DB_USER=
DEEPFAKE_DB_PASSWORD=
DEEPFAKE_SQLITE_PATH=./data/app.db
DATABASE_URL=sqlite:///./data/app.db

# === CONFIGURAÇÕES DE LOGGING ===
DEEPFAKE_LOG_LEVEL=INFO
DEEPFAKE_LOG_FILE_ENABLED=true
DEEPFAKE_LOG_FILE_PATH=./logs/deepfake_system.log
DEEPFAKE_LOG_CONSOLE_ENABLED=true
DEEPFAKE_LOG_JSON_FORMAT=false

# === CONFIGURAÇÕES DE MONITORAMENTO ===
DEEPFAKE_MONITORING_ENABLED=true
DEEPFAKE_METRICS_ENABLED=true
DEEPFAKE_PERFORMANCE_TRACKING=true
DEEPFAKE_ERROR_TRACKING=true
DEEPFAKE_MEMORY_MONITORING=true

# === CONFIGURAÇÕES DE SEGURANÇA ===
DEEPFAKE_AUTH_ENABLED=false
DEEPFAKE_JWT_SECRET=your-secret-key-here
DEEPFAKE_JWT_EXPIRATION_HOURS=24
DEEPFAKE_PASSWORD_MIN_LENGTH=8
DEEPFAKE_MAX_LOGIN_ATTEMPTS=5
DEEPFAKE_MAX_FILE_SIZE_MB=100
DEEPFAKE_SCAN_UPLOADS=true

# === CONFIGURAÇÕES ESPECÍFICAS DO ARQUIVO ===
# Caminho para arquivo de configuração JSON (opcional)
DEEPFAKE_CONFIG_FILE=./config.json

# === CONFIGURAÇÕES DE DESENVOLVIMENTO ===
# Ativar modo de desenvolvimento com logs detalhados
DEEPFAKE_DEV_MODE=true

# Ativar profiling de performance
DEEPFAKE_PROFILING=false

# Ativar modo de teste
DEEPFAKE_TEST_MODE=false

# === CONFIGURAÇÕES DE PRODUÇÃO ===
# Para ambiente de produção, ajuste estas variáveis:
# DEEPFAKE_ENV=production
# DEEPFAKE_DEBUG=false
# DEEPFAKE_LOG_LEVEL=WARNING
# DEEPFAKE_API_DEBUG=false
# DEEPFAKE_AUTH_ENABLED=true
# DEEPFAKE_JWT_SECRET=your-production-secret-key
# DEEPFAKE_CORS_ENABLED=false

# === CONFIGURAÇÕES OPCIONAIS ===
# Configurações avançadas que podem ser definidas se necessário

# Configurações de cache
# DEEPFAKE_CACHE_ENABLED=true
# DEEPFAKE_CACHE_TTL=3600

# Configurações de rede
# DEEPFAKE_PROXY_URL=
# DEEPFAKE_TIMEOUT_SECONDS=30

# Configurações de GPU
# DEEPFAKE_USE_GPU=true
# DEEPFAKE_GPU_MEMORY_LIMIT=4096
# XFAKE_GPU_MEMORY_GROWTH=true
# XFAKE_GPU_MEMORY_LIMIT_MB=
# XFAKE_CUDA_MALLOC_ASYNC=true
# XFAKE_ENABLE_XLA=true
# XFAKE_ENABLE_ONEDNN=true
# XFAKE_TF_INTRA_OP_THREADS=
# XFAKE_TF_INTER_OP_THREADS=
# XFAKE_NUM_WORKERS=
# XFAKE_MAX_UPLOAD_MB=100
# XFAKE_SLOW_REQUEST_MS=1500
# XFAKE_LOG_EVERY_REQUEST=false

# Configurações de paralelização
# DEEPFAKE_PARALLEL_JOBS=4
# DEEPFAKE_THREAD_POOL_SIZE=8

# === DOCKER / COMPOSE — limites de recurso ===
# Lidos pelos docker-compose*.yml e docker/compose/*.yml. Ajuste ao seu host.
# Versão do Python das imagens (3.11 é a referência; faixa suportada 3.11–3.12).
# PYTHON_VERSION=3.11
# Porta publicada do Gradio/inferência.
# GRADIO_PORT=7860
# Container de inferência (leve): CPUs e memória.
# DOCKER_CPU_LIMIT=4
# DOCKER_MEMORY_LIMIT=8G
# Container de treino/benchmark (pesado): CPUs e memória. Não exceda a VM do
# WSL2 (ver ~/.wslconfig: processors / memory).
# DOCKER_TRAIN_CPU_LIMIT=8
# DOCKER_TRAIN_MEMORY_LIMIT=16G
# GPU NVIDIA (perfis .nvidia). Use 1 GPU específica ou "all".
# NVIDIA_GPU_COUNT=1
# NVIDIA_VISIBLE_DEVICES=0
